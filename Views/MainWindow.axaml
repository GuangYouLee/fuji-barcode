<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:fuji_barcode.ViewModels"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="350"
        x:Class="fuji_barcode.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Fuji Barcode Scanner"
        Width="500" Height="350"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">
    <TextBox Grid.Row="0"
             Name="ScanInput"
             Text="{Binding ScanText}"
             Watermark="Scan barcode..."
             IsEnabled="{Binding CanScan}" />

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0" Spacing="12">
      <RadioButton Content="Object ID"
                   IsChecked="{Binding IsObjectIdMode}" />
      <RadioButton Content="Recipe"
                   IsChecked="{Binding IsRecipeMode}" />
    </StackPanel>

    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0" Spacing="8">
      <Button Content="Submit"
              Command="{Binding SubmitCommand}"
              IsDefault="True"
              MinWidth="90" />
      <Button Content="Admin"
              Click="OpenAdminWindow"
              MinWidth="90" />
    </StackPanel>

    <Separator Grid.Row="3" Margin="0,12,0,8" />

    <TextBlock Grid.Row="4"
               Text="{Binding StatusText}"
               TextWrapping="Wrap" />
  </Grid>
</Window>
